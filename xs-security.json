{
 "xsappname": "mycapapp",
 "tenant-mode": "dedicated",
 "scopes": [
  {
   "name": "$XSAPPNAME.Display",
   "description": "display"
  },
  {
   "name": "$XSAPPNAME.Edit",
   "description": "edit"
  },
  {
   "name": "$XSAPPNAME.Delete",
   "description": "delete"
  },
  {
   "name": "$XSAPPNAME.mtcallback",
   "description": "Subscription via SaaS Registry",
   "grant-as-authority-to-apps": [
    "$XSAPPNAME(application,sap-provisioning,tenant-onboarding)"
   ]
  }
 ],
 "attributes": [
  {
   "name": "spiderman",
   "description": "Bank Name which will control row level security",
   "valueType": "string"
  }
 ],
 "role-templates": [
  {
   "name": "Viewer",
   "description": "View all data of PO and Employees",
   "default-role-name": "Viewer: Authorized to Read All PO and Employees",
   "scope-references": [
    "$XSAPPNAME.Display"
   ],
   "attribute-references": [
    {
     "name": "spiderman"
    }
   ]
  },
  {
   "name": "Editor",
   "description": "Edit, delete PO and Employees",
   "scope-references": [
    "$XSAPPNAME.Edit",
    "$XSAPPNAME.Delete"
   ]
  }
 ],
 "authorities": [
  "$ACCEPT_GRANTED_AUTHORITIES"
 ],
 "oauth2-configuration": {
  "token-validity": 9000,
  "redirect-uris": [
   "https://*.cfapps.us10-001.hana.ondemand.com/login/callback"
  ]
 },
 "xsenableasyncservice": "true",
 "authorities-inheritance": false
}
